# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: SQLite)
# Option A — single URL (postgresql:// or postgres://):
# DATABASE_URL=postgresql://dig_fit:YOUR_PASSWORD@127.0.0.1:5432/dig_fit
# Option B — discrete vars (used when DATABASE_URL is unset):
# POSTGRES_USER=dig_fit
# POSTGRES_PASSWORD=YOUR_PASSWORD
# POSTGRES_DB=dig_fit
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

# Ollama (install from https://ollama.com — e.g. `ollama pull medgemma:4b`)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=medgemma:4b

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Stripe Configuration
STRIPE_PUBLIC_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_ID=your-stripe-price-id

# Security Settings
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://yourdomain.com
