  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (get API token)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"your-password\"\n}"
            },
            "description": "Public endpoint. Copy `token` from the response into the collection variable `api_token`, then use other folders."
          }
        },
        {
          "name": "Logout (delete API token)",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/auth/logout/"
          }
        }
      ]
    },
