{
  "info": {
    "_postman_id": "digfit-api-collection",
    "name": "DigFit API",
    "description": "REST API for DigFit (Django REST Framework).\n\n**Setup:** Import this file in Postman. Set `base_url` (default `http://127.0.0.1:8000`). Run **Auth → Login** first; copy `token` into collection variable **`api_token`**. Collection auth sends `Authorization: Token {{api_token}}` on other requests. **Do not use Postman’s “Bearer Token” auth** — DRF expects the header `Authorization: Token <key>` exactly. For Login, the request uses **no auth** so the body is not overridden.\n\n**Alternative:** MCP internal requests use the `X-MCP-Token` header (see `DJANGO_MCP` / `MCP_INTERNAL_TOKEN` in settings); Postman does not set this by default.\n\n**Roles:** Admin-only routes require `is_staff`. See `API.md` for field lists and examples.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "Authorization",
        "type": "string"
      },
      {
        "key": "value",
        "value": "Token {{api_token}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "api_token",
      "value": ""
    },
    {
      "key": "plan_slug",
      "value": "starter"
    },
    {
      "key": "user_id",
      "value": "1"
    },
    {
      "key": "settings_id",
      "value": "1"
    },
    {
      "key": "weight_id",
      "value": "1"
    },
    {
      "key": "meal_plan_id",
      "value": "1"
    },
    {
      "key": "user_meal_id",
      "value": "1"
    },
    {
      "key": "intervention_id",
      "value": "1"
    },
    {
      "key": "stripe_customer_id",
      "value": "1"
    }
